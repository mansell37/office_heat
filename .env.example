# Copy to .env for local dev. On Railway, set these as service variables.

# --- App ---
# Shared password gate. If left empty, the app runs OPEN (fine for local dev only).
APP_PASSWORD=
# Secret used to sign the auth cookie. Any long random string.
SECRET_KEY=change-me-to-a-long-random-string

# --- Database ---
# Local dev defaults to a SQLite file if unset. Railway injects DATABASE_URL automatically.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Claude (server-side only) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Garmin (for uploading bike workouts) ---
# Preferred: a pre-generated token (base64 of garth dumps) — avoids MFA login.
# Account-level, so a token from another app (e.g. ripe_fitness) works here too.
# Generate one with: backend/scripts/garmin_bootstrap.py
GARMIN_TOKENS_B64=
# Optional fallback if you have no token: direct login (may hit MFA in the cloud).
GARMIN_EMAIL=
GARMIN_PASSWORD=

# --- Defaults ---
DEFAULT_FTP=200
